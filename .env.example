# ═══ PrintKaaro Backend Config ═══

# MongoDB Atlas connection string (replace with yours)
MONGODB_URI=mongodb+srv://printkaaro:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/printkaaro?retryWrites=true&w=majority

# JWT secret for auth tokens (change this to any random string)
JWT_SECRET=printkaaro-super-secret-key-change-this-2026

# Admin password for dashboard
ADMIN_PASSWORD=admin123

# Server port
PORT=4000

# Frontend URL (for CORS)
FRONTEND_URL=https://printkaaro.in

# File upload max size (in bytes, 50MB)
MAX_FILE_SIZE=52428800
